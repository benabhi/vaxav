---
import AdminLayout from "../../../layouts/AdminLayout.astro";

// Aquí irían funciones para procesar el formulario en un enfoque basado en API
---

<AdminLayout title="Create New Universe" activeSection="universe">
    <div class="universe-form">
        <form id="createUniverseForm" method="POST">
            <div class="form-section">
                <h3>Basic Information</h3>

                <div class="form-group">
                    <label for="name">Universe Name</label>
                    <input type="text" id="name" name="name" required />
                    <small>Choose a distinctive name for your universe</small>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea
                        id="description"
                        name="description"
                        rows="4"
                        required></textarea>
                    <small
                        >Describe the key characteristics of this universe</small
                    >
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="status">Status</label>
                        <select id="status" name="status" required>
                            <option value="draft">Draft</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="visibility">Visibility</label>
                        <select id="visibility" name="visibility" required>
                            <option value="public">Public</option>
                            <option value="private">Private</option>
                            <option value="restricted">Restricted</option>
                        </select>
                        <small>Who can access this universe</small>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3>Universe Rules & Parameters</h3>

                <div class="form-group">
                    <label for="physicRules">Physical Laws</label>
                    <select id="physicRules" name="physicRules" required>
                        <option value="standard">Standard Physics</option>
                        <option value="modified">Modified Physics</option>
                        <option value="fantasy">Fantasy Physics</option>
                        <option value="custom">Custom Rules</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="magicSystem">Magic System</label>
                    <select id="magicSystem" name="magicSystem">
                        <option value="none">No Magic</option>
                        <option value="elemental">Elemental Magic</option>
                        <option value="runic">Runic Magic</option>
                        <option value="divine">Divine Power</option>
                        <option value="custom">Custom Magic System</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="technologyLevel">Technology Level</label>
                    <select
                        id="technologyLevel"
                        name="technologyLevel"
                        required
                    >
                        <option value="primitive">Primitive</option>
                        <option value="medieval">Medieval</option>
                        <option value="industrial">Industrial</option>
                        <option value="modern">Modern</option>
                        <option value="advanced">Advanced</option>
                        <option value="futuristic">Futuristic</option>
                        <option value="custom">Custom Mix</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="customRules">Custom Rules (Optional)</label>
                    <textarea id="customRules" name="customRules" rows="4"
                    ></textarea>
                    <small
                        >Describe any custom rules that govern this universe</small
                    >
                </div>
            </div>

            <div class="form-section">
                <h3>Geography & Structure</h3>

                <div class="form-group">
                    <label for="worldStructure">World Structure</label>
                    <select id="worldStructure" name="worldStructure" required>
                        <option value="planet">Single Planet</option>
                        <option value="system">Solar System</option>
                        <option value="galaxy">Galaxy</option>
                        <option value="multiverse">Multiverse</option>
                        <option value="plane">Planar Structure</option>
                        <option value="custom">Custom Structure</option>
                    </select>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="regions">Number of Regions</label>
                        <input
                            type="number"
                            id="regions"
                            name="regions"
                            min="1"
                            max="50"
                            value="5"
                        />
                    </div>

                    <div class="form-group">
                        <label for="mapSize">Map Size</label>
                        <select id="mapSize" name="mapSize">
                            <option value="small">Small</option>
                            <option value="medium" selected>Medium</option>
                            <option value="large">Large</option>
                            <option value="vast">Vast</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Terrain Types</label>
                    <div class="checkbox-group">
                        <label
                            ><input
                                type="checkbox"
                                name="terrain"
                                value="mountains"
                            /> Mountains</label
                        >
                        <label
                            ><input
                                type="checkbox"
                                name="terrain"
                                value="forests"
                            /> Forests</label
                        >
                        <label
                            ><input
                                type="checkbox"
                                name="terrain"
                                value="oceans"
                            /> Oceans</label
                        >
                        <label
                            ><input
                                type="checkbox"
                                name="terrain"
                                value="deserts"
                            /> Deserts</label
                        >
                        <label
                            ><input
                                type="checkbox"
                                name="terrain"
                                value="plains"
                            /> Plains</label
                        >
                        <label
                            ><input
                                type="checkbox"
                                name="terrain"
                                value="tundra"
                            /> Tundra</label
                        >
                        <label
                            ><input
                                type="checkbox"
                                name="terrain"
                                value="volcanic"
                            /> Volcanic</label
                        >
                        <label
                            ><input
                                type="checkbox"
                                name="terrain"
                                value="floating"
                            /> Floating Lands</label
                        >
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h3>Inhabitants</h3>

                <div class="form-group">
                    <label for="races">Races/Species</label>
                    <textarea
                        id="races"
                        name="races"
                        rows="4"
                        placeholder="Humans, Elves, Dwarves, etc."></textarea>
                    <small
                        >List the main races or species that inhabit this
                        universe</small
                    >
                </div>

                <div class="form-group">
                    <label for="factions">Factions/Nations</label>
                    <textarea
                        id="factions"
                        name="factions"
                        rows="4"
                        placeholder="Empire of the North, Southern Kingdom, etc."
                    ></textarea>
                    <small
                        >List the main political groups in your universe</small
                    >
                </div>

                <div class="form-group">
                    <label for="populationDensity">Population Density</label>
                    <select id="populationDensity" name="populationDensity">
                        <option value="sparse">Sparse</option>
                        <option value="normal" selected>Normal</option>
                        <option value="dense">Dense</option>
                        <option value="overcrowded">Overcrowded</option>
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="cancel-button">Cancel</button>
                <button type="button" class="save-draft-button"
                    >Save as Draft</button
                >
                <button type="submit" class="submit-button"
                    >Create Universe</button
                >
            </div>
        </form>
    </div>

    <script>
        // Client-side form handling
        document.addEventListener("DOMContentLoaded", () => {
            const form = document.getElementById("createUniverseForm");

            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                // Form validation would go here

                // In a real application, you would submit this to an API
                const formData = new FormData(form);
                const formValues = Object.fromEntries(formData.entries());

                // For terrain checkboxes which can have multiple values
                formValues.terrain = formData.getAll("terrain");

                console.log("Form data to submit:", formValues);

                // Simulating API call
                try {
                    // Here you would make an actual fetch request to your backend
                    // await fetch('/api/universe', { method: 'POST', body: formData });

                    // For demo purposes, we'll just simulate a delay
                    await new Promise((resolve) => setTimeout(resolve, 1000));

                    // Redirect after successful creation
                    window.location.href = "/admin/universe?created=true";
                } catch (error) {
                    console.error("Error creating universe:", error);
                    // Show error message to user
                }
            });

            // Handle the save draft button
            document
                .querySelector(".save-draft-button")
                .addEventListener("click", () => {
                    // Set status to draft
                    document.getElementById("status").value = "draft";
                    // Submit the form
                    form.dispatchEvent(new Event("submit"));
                });

            // Handle cancel button
            document
                .querySelector(".cancel-button")
                .addEventListener("click", () => {
                    if (
                        confirm(
                            "Are you sure you want to cancel? All changes will be lost.",
                        )
                    ) {
                        window.location.href = "/admin/universe";
                    }
                });
        });
    </script>
</AdminLayout>

<style>
    .universe-form {
        max-width: 100%;
    }

    .form-section {
        background-color: #f9f9f9;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 25px;
        border: 1px solid #e0e0e0;
    }

    .form-section h3 {
        margin-top: 0;
        margin-bottom: 20px;
        color: #333;
        border-bottom: 1px solid #ddd;
        padding-bottom: 10px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    label {
        display: block;
        margin-bottom: 5px;
        font-weight: 500;
    }

    input[type="text"],
    input[type="number"],
    select,
    textarea {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 16px;
    }

    small {
        display: block;
        margin-top: 5px;
        color: #777;
        font-size: 0.85rem;
    }

    .checkbox-group {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 10px;
    }

    .checkbox-group label {
        display: flex;
        align-items: center;
        font-weight: normal;
    }

    .checkbox-group input[type="checkbox"] {
        margin-right: 8px;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 30px;
    }

    button {
        padding: 10px 20px;
        border-radius: 4px;
        font-size: 16px;
        cursor: pointer;
        border: none;
    }

    .cancel-button {
        background-color: #f0f0f0;
        color: #333;
    }

    .save-draft-button {
        background-color: #e6f0f7;
        color: #2a71b5;
    }

    .submit-button {
        background-color: #3751ff;
        color: white;
        font-weight: 500;
    }

    @media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .checkbox-group {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>
